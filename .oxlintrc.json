{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "typescript",
    "unicorn",
    "oxc",
    "import",
    "node",
    "react",
    "react-perf",
    "promise"
  ],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "react/jsx-no-target-blank": "error"
  },
  "env": {
    "builtin": true
  }
}
