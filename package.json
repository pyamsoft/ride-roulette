{
  "name": "ride-roulette",
  "version": "0.4.4",
  "type": "module",
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "9.1.1",
    "@mui/material": "9.1.1",
    "jotai": "2.20.1",
    "react": "19.2.7",
    "react-confetti": "6.4.0",
    "react-dom": "19.2.7",
    "react-window": "2.2.7",
    "uuid": "14.0.0"
  },
  "scripts": {
    "start": "vite",
    "lint:eslint": "eslint --report-unused-disable-directives --max-warnings 0 --cache --cache-strategy content .",
    "lint:oxlint": "oxlint --deny-warnings .",
    "lint:stylelint": "stylelint 'src/**/*.css'",
    "lint:tsc": "tsc --strict --noEmit",
    "lint": "$npm_execpath run lint:oxlint && $npm_execpath run lint:tsc && $npm_execpath run lint:stylelint && $npm_execpath run lint:eslint",
    "build": "$npm_execpath run lint && vite build",
    "build:preview": "$npm_execpath run build && $npm_execpath run preview",
    "preview": "vite preview",
    "test": "vitest --ui",
    "coverage": "vitest run --coverage",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@jest/globals": "30.4.1",
    "@rolldown/plugin-babel": "0.2.3",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/jest": "30.0.0",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.61.0",
    "@typescript-eslint/parser": "8.61.0",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.8",
    "@vitest/ui": "4.1.8",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "10.5.0",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.6.0",
    "jsdom": "29.1.1",
    "npm-check-updates": "22.2.3",
    "oxlint": "1.69.0",
    "prettier": "3.8.4",
    "stylelint": "17.13.0",
    "stylelint-config-standard": "40.0.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0",
    "vite": "8.0.16",
    "vite-plugin-checker": "0.14.1",
    "vitest": "4.1.8",
    "web-vitals": "5.3.0"
  },
  "packageManager": "pnpm@11.6.0"
}
